platform :ios, '15.0'

def mapkit_pod
  pod 'YandexMapsMobile', :path => 'bundle'
end

target 'MapWithPlacemark' do
  mapkit_pod
end

target 'MapInteraction' do
  mapkit_pod
end

target 'MapObjects' do
  mapkit_pod
end

target 'MapSearch' do
  mapkit_pod
end

target 'MapRouting' do
  mapkit_pod
end
